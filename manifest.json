{
  "manifest_version": 3,
  "name": "EZE3",
  "version": "1.0.0",
  "description": "Premium browser automation for NYCU Portal. Easy access, zero friction.",
  "permissions": ["storage"],
  "options_page": "options.html",
  "action": {
    "default_title": "EZE3",
    "default_popup": "options.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://portal.nycu.edu.tw/*",
        "https://e3p.nycu.edu.tw/login/index.php*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
